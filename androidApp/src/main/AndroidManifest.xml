            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/afdian_product_widget_info" />
        </receiver>
        <receiver
            android:name=".widget.AfdianDailyEarningsChartWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_afdian_daily_chart">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
